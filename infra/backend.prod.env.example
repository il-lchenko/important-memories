APP_ENV=production
LOG_LEVEL=INFO

# PostgreSQL — должно совпадать с docker-compose.prod.yml
DATABASE_URL=postgresql+psycopg://imuser:CHANGE_ME@postgres:5432/im
POSTGRES_DB=im
POSTGRES_USER=imuser
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — сгенерировать: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_CHARS
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# SMTP — настоящая почта (Яндекс 360, Mail.ru, etc.)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=CHANGE_ME
SMTP_TLS=true
SMTP_FROM=noreply@yourdomain.ru
SMTP_FROM_NAME=Important Memories

# MinIO — должно совпадать с docker-compose.prod.yml
S3_ENDPOINT=http://minio:9000
S3_REGION=ru-central1
S3_BUCKET=im-media
S3_ACCESS_KEY=imadmin
S3_SECRET_KEY=CHANGE_ME
MINIO_ROOT_USER=imadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# Публичный URL сервера (для ссылок в письмах, presigned URLs)
PUBLIC_API_BASE_URL=https://YOUR_DOMAIN_OR_IP
PUBLIC_PWA_BASE_URL=https://YOUR_DOMAIN_OR_IP

# CORS — список разрешённых origins
CORS_ORIGINS=["https://YOUR_DOMAIN_OR_IP"]

# ЮКасса (оставить пустым если не используется)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

# Sentry (опционально)
SENTRY_DSN=
