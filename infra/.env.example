APP_ENV=production
LOG_LEVEL=INFO

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=im
POSTGRES_USER=imuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# URL для бэкенда (хост = имя сервиса в docker-compose)
DATABASE_URL=postgresql+psycopg://imuser:CHANGE_ME_STRONG_PASSWORD@postgres:5432/im

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT — сгенерировать: openssl rand -hex 32 ──────────────
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ── MinIO (S3) ─────────────────────────────────────────────
MINIO_ROOT_USER=imadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

S3_ENDPOINT=http://minio:9000
S3_REGION=ru-central1
S3_BUCKET=im-media
S3_ACCESS_KEY=imadmin
S3_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD

# ── SMTP ───────────────────────────────────────────────────
# Пример для Яндекс 360 / mail.ru / другого SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=CHANGE_ME
SMTP_TLS=true
SMTP_FROM=noreply@yourdomain.ru
SMTP_FROM_NAME=Important Memories

# ── Публичные URL ──────────────────────────────────────────
# Сейчас — IP, потом заменить на домен
PUBLIC_API_BASE_URL=http://217.149.29.227
PUBLIC_PWA_BASE_URL=http://217.149.29.227
CORS_ORIGINS=["http://217.149.29.227"]

# ── ЮКасса (оставить пустым для MVP) ──────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

# ── Sentry (опционально) ───────────────────────────────────
SENTRY_DSN=
